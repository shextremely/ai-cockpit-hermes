# ===== Hermes Agent =====
# 与 ~/.hermes/.env 中 API_SERVER_* 保持一致
HERMES_BASE_URL=http://127.0.0.1:5173
# Hermes API 密钥(只在 BFF 服务端使用,严禁进浏览器)
# 值 = ~/.hermes/.env 中的 API_SERVER_KEY(自行设定,非网上申请)
HERMES_API_KEY=replace-with-your-api-server-key
HERMES_SESSION_KEY=agent:main:cockpit:user-self
HERMES_MODEL=hermes-agent

# ===== BFF =====
BFF_PORT=5180
# 开发期前端 origin(Vite 默认 5174,与 Hermes 5173 错开)
BFF_ALLOW_ORIGIN=http://localhost:5174
# BFF 本机登录口令(可选;留空则不启用)
BFF_AUTH_TOKEN=

# ===== Obsidian 知识库(本机 Vault,仅 BFF 用于打开笔记) =====
OBSIDIAN_VAULT_PATH=F:/Documents/SecondBrain
KNOWLEDGE_OPEN_MODE=typora
# TYPORA_PATH=

# ===== Claude Code 引擎(对话/技能执行主引擎) =====
# Claude 技能目录(能力面板技能列表)
# CLAUDE_SKILLS_PATH=C:/Users/<you>/.claude/skills
# Claude Code CLI 可执行名/绝对路径
CLAUDE_BIN=claude
# Claude 运行工作目录(默认仓库根)
# CLAUDE_CWD=E:/ai-cockpit-hermes
CLAUDE_ALLOWED_TOOLS=Read,Edit,Write,Bash,Glob,Grep,Skill,Task,WebSearch,WebFetch
CLAUDE_PERMISSION_MODE=bypassPermissions
CLAUDE_MAX_TURNS=30
# CLAUDE_MODEL=

# ===== 双引擎对话路由 =====
# 默认对话引擎: claude | hermes
CHAT_BACKEND=claude

# ===== Cursor(代码修复/开发时由 BFF 打开工程) =====
CURSOR_BIN=cursor
# CURSOR_DEFAULT_REPO=E:/ai-cockpit-hermes

# ===== 前端(仅 VITE_ 前缀注入浏览器;禁止放密钥) =====
VITE_BFF_BASE_URL=/api
